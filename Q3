import numpy as np
import matplotlib.pyplot as plt

def generate_signal():
    n = np.array([-2,-1,0,1,2])
    x = np.array([-2,-2,0,2,2])
    return n,x

n,x = generate_signal()

plt.figure(figsize=(8,4))
plt.plot(n,x)
plt.grid()
plt.title('Signal 3')
plt.xlabel('n')
plt.ylabel('Amplitude')
plt.show()
